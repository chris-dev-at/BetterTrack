{
  "name": "bettertrack",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:infra": "docker compose -f infra/docker-compose.dev.yml up -d",
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "build": "pnpm -r build",
    "clean": "pnpm -r exec rm -rf dist coverage .tsbuildinfo",
    "knowledge:build": "node factory/knowledge/build.mjs"
  },
  "devDependencies": {
    "@bettertrack/config": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.0",
    "eslint": "^9.19.0",
    "prettier": "^3.4.2",
    "typescript": "~5.7.3"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}

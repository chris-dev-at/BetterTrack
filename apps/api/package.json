{
  "name": "@bettertrack/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker": "tsx src/scripts/worker.ts",
    "worker:dev": "tsx watch src/scripts/worker.ts",
    "start": "node dist/server.js",
    "start:worker": "node dist/scripts/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:openapi-coverage": "tsx src/scripts/checkOpenapiCoverage.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "build": "tsup",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "admin:break-glass": "tsx src/scripts/adminTwoFactorBreakGlass.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@bettertrack/contracts": "workspace:*",
    "@bull-board/api": "^6.21.3",
    "@bull-board/express": "^6.21.3",
    "@node-rs/argon2": "^2.0.2",
    "@sentry/node": "^10.65.0",
    "bullmq": "^5.78.1",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.38.3",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "fflate": "^0.8.3",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jose": "^5.10.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.0",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.2.0",
    "socket.io": "^4.8.3",
    "uuidv7": "^1.0.2",
    "web-push": "^3.6.7",
    "yahoo-finance2": "^3.15.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@bettertrack/config": "workspace:*",
    "@electric-sql/pglite": "^0.2.17",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/ioredis-mock": "^8.2.5",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.30.1",
    "ioredis-mock": "^8.9.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "~5.7.3",
    "vitest": "^3.0.5"
  }
}

# Copy to apps/api/.env (or your process manager's env) and adjust.
# See PROJECTPLAN.md §11 for the full configuration reference.

# Data layer (matches infra/docker-compose.dev.yml)
DATABASE_URL=postgres://bt:bt@localhost:5432/bettertrack
REDIS_URL=redis://localhost:6379

# API
PORT=3000
APP_ORIGIN=http://localhost:5173
SESSION_SECRET=change-me-to-64-random-bytes

# SMTP — leave empty to keep the email channel disabled; the app still runs.
# The channel turns on only when both SMTP_HOST and SMTP_FROM are set. Port 465
# uses implicit TLS; any other port negotiates STARTTLS. SMTP_USER/PASS are
# optional (omit for unauthenticated relays). See README "Email (SMTP)".
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Seeds the first admin on first boot only (later phase).
ADMIN_EMAIL=
ADMIN_PASSWORD=

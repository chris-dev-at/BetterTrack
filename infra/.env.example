# Copy to apps/api/.env (or your process manager's env) and adjust.
# See PROJECTPLAN.md §11 for the full configuration reference.

# Data layer (matches infra/docker-compose.dev.yml)
DATABASE_URL=postgres://bt:bt@localhost:5432/bettertrack
REDIS_URL=redis://localhost:6379

# API process listen port (internal). The public API *origin* is derived from
# the topology below (BT_*), which may differ from this in a real deployment.
PORT=3000
# 64 random bytes recommended (openssl rand -hex 64); comma-separate for rotation.
SESSION_SECRET=change-me-to-64-random-bytes

# ── Deployment topology (§4.6, §11) ──────────────────────────────────────────
# One scheme drives every public origin; CORS + cookie attributes are DERIVED
# from it (never hand-maintained). Two modes, five origins each — api/web/admin
# plus the static product (apex) + mobile. landing pages:
#   subdomains → https://{sub}.{BT_DOMAIN}   (api./web./admin./mobile. + apex product)
#   ports      → http(s)://{BT_DOMAIN}:{port}
BT_MODE=subdomains
BT_DOMAIN=localhost
# TLS scheme of derived origins. Blank = per-mode default (subdomains https,
# ports http). Set true/false to force it.
BT_TLS=
# Subdomain names (subdomains mode). The product landing has NO subdomain — it is
# served from BT_DOMAIN's apex; only the mobile placeholder gets a label.
BT_SUB_API=api
BT_SUB_WEB=web
BT_SUB_ADMIN=admin
BT_SUB_MOBILE=mobile
# Service ports (ports mode). BT_PORT_API is the public API port; the API process
# still listens on PORT above and is proxied to it. PRODUCT/MOBILE front the
# static landing pages.
BT_PORT_API=3000
BT_PORT_WEB=8080
BT_PORT_ADMIN=8081
BT_PORT_PRODUCT=8082
BT_PORT_MOBILE=8083
# Explicit origin overrides — win over derivation. For LOCAL dev the SPA runs on
# the Vite dev server (5173) and proxies /api same-origin, so point the derived
# origins at it. APP_ORIGIN is a legacy alias for BT_WEB_ORIGIN. The static
# product/mobile pages aren't exercised in local dev — leave their overrides blank.
BT_API_ORIGIN=http://localhost:3000
BT_WEB_ORIGIN=http://localhost:5173
BT_ADMIN_ORIGIN=http://localhost:5173
BT_PRODUCT_ORIGIN=
BT_MOBILE_ORIGIN=

# ── SMTP (optional) ──────────────────────────────────────────────────────────
# Leave empty to keep the email channel disabled; the app still runs fully.
# The channel turns on only when both SMTP_HOST and SMTP_FROM are set. Port 465
# uses implicit TLS; any other port negotiates STARTTLS. SMTP_USER/PASS are
# optional (omit for unauthenticated relays). See README "Email (SMTP)".
#
# Gmail preset (recommended): create an App Password (Google Account → Security →
# 2-Step Verification → App passwords) and use it as SMTP_PASS.
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-16-char-app-password
#   SMTP_FROM=BetterTrack <you@gmail.com>
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Seeds the first admin on first boot only (later phase).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Copy to infra/.env and fill in all required values before running compose.
# See PROJECTPLAN.md §11 for the full configuration reference.

# ── Database ────────────────────────────────────────────────────────────────
# Credentials used by both the db service and the api service.
# DATABASE_URL must use the compose service hostname "db", not localhost.
POSTGRES_USER=bt
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=bettertrack
DATABASE_URL=postgres://bt:CHANGE_ME_STRONG_PASSWORD@db:5432/bettertrack

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── API ──────────────────────────────────────────────────────────────────────
# SESSION_SECRET: 64 random bytes (hex). Generate with:
#   openssl rand -hex 64
# Comma-separate multiple secrets for zero-downtime rotation (first signs new cookies).
SESSION_SECRET=CHANGE_ME_64_RANDOM_HEX_BYTES

# ── Deployment topology (§4.6, §10, §11) ─────────────────────────────────────
# One scheme drives the api/web/admin origins; CORS allowlist + cookie Secure/
# SameSite are DERIVED from it (never hand-maintained). Pick ONE mode.
#
# Mode A — subdomains (default). Front this proxy with TLS (Caddy/Traefik/
# Cloudflare) and point five DNS records at it (see README "Production deploy").
# Origins become:
#   product → https://track.example.at            (apex — the static landing page)
#   web     → https://web.track.example.at
#   admin   → https://admin.track.example.at
#   api     → https://api.track.example.at
#   mobile  → https://mobile.track.example.at     (static placeholder)
BT_MODE=subdomains
BT_DOMAIN=track.example.at
# Front-proxy TLS. Leave blank for the per-mode default (subdomains → https).
BT_TLS=
# Subdomain labels (change to taste; the same web image serves web + admin). The
# product landing has NO label — it lives at the BT_DOMAIN apex; mobile. is the
# static placeholder subdomain.
BT_SUB_API=api
BT_SUB_WEB=web
BT_SUB_ADMIN=admin
BT_SUB_MOBILE=mobile
# Host port the proxy listens on (subdomains mode). Terminate TLS in front of it.
# The one proxy port fronts all five origins.
BT_HTTP_PORT=80
#
# Mode B — ports. One host, each service on its own port. To use it, set:
#   BT_MODE=ports
#   BT_DOMAIN=track.example.at   (or a bare IP)
#   BT_TLS=false                 (or true if you terminate TLS in front)
# and the ports below. Origins become http(s)://{BT_DOMAIN}:{port}. PRODUCT and
# MOBILE front the static landing pages, proxied to the internal landing container.
BT_PORT_API=3000
BT_PORT_WEB=8080
BT_PORT_ADMIN=8081
BT_PORT_PRODUCT=8082
BT_PORT_MOBILE=8083
#
# Explicit origin overrides — win over derivation (split hosting / legacy).
# APP_ORIGIN is a legacy alias for BT_WEB_ORIGIN. The static product/mobile pages
# take no credentials, so they never enter the CORS allowlist regardless.
BT_API_ORIGIN=
BT_WEB_ORIGIN=
BT_ADMIN_ORIGIN=
BT_PRODUCT_ORIGIN=
BT_MOBILE_ORIGIN=

# ── SMTP (optional) ──────────────────────────────────────────────────────────
# Leave empty to keep the email channel disabled; the app still runs fully.
# Both SMTP_HOST and SMTP_FROM must be set to enable email delivery.
#
# Gmail preset (recommended): create an App Password (Google Account → Security →
# 2-Step Verification → App passwords) and use it as SMTP_PASS.
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-16-char-app-password
#   SMTP_FROM=BetterTrack <you@gmail.com>
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Push channels (optional, #368) ───────────────────────────────────────────
# Phone push (FCM HTTP v1): absolute in-container path to the Firebase
# service-account JSON, mounted read-only via a compose override — the key is a
# SERVER SECRET and never belongs in a repo or image. Unset (or file missing)
# ⇒ the channel is cleanly disabled with one boot warn; nothing crashes.
BT_FCM_SERVICE_ACCOUNT_FILE=
# Browser push (web-push/VAPID): generate a pair with `npx web-push
# generate-vapid-keys`. Both keys set ⇒ the "Browser push" column appears in
# notification settings. Subject defaults to mailto:admin@$BT_DOMAIN.
BT_VAPID_PUBLIC_KEY=
BT_VAPID_PRIVATE_KEY=
BT_VAPID_SUBJECT=

# ── Backups (§10, §13.4 V4-P6) ───────────────────────────────────────────────
# Local dumps — infra/backup/backup.sh runs inside the `db` container (host
# cron triggers it nightly) and writes a gzip'd pg_dump into the `pgbackups`
# volume, pruning anything older than BACKUP_RETENTION_DAYS. See README.md
# "Backups & restore" for the cron line and the restore procedure.
BACKUP_RETENTION_DAYS=14

# ── Offsite backup (optional; §13.4 V4-P6 arc-b) ─────────────────────────────
# When configured, an OPTIONAL sidecar (infra/docker-compose.offsite.yml)
# encrypts the newest local dump to an owner-provided age recipient and
# uploads it via rclone (Google Drive in production). See docs/ops.md for
# key generation, remote setup, and the restore drill.
#
# Env-gated end to end: leave BT_BACKUP_RCLONE_REMOTE unset (or don't include
# the override) and the nightly job behaves exactly as today. When the
# override IS included, both HOST paths below must be set — the sidecar
# bind-mounts them into fixed in-container paths, keeping secrets on the
# host filesystem and out of the repo/image.
#
# Preferred: age. The recipient file holds one or more public `age1...`
# lines; the matching identity (private key) stays OFFLINE with the owner.
BT_BACKUP_AGE_RECIPIENT_HOST_FILE=
# rclone.conf holds the Drive OAuth tokens for the remote — treat as secret.
BT_BACKUP_RCLONE_CONFIG_HOST_FILE=
# rclone remote target, e.g. `gdrive:bettertrack-backups`. Empty ⇒ skip.
BT_BACKUP_RCLONE_REMOTE=
# Remote retention window in days (default 30 per V4-P6 arc-b acceptance).
BT_BACKUP_REMOTE_RETENTION_DAYS=30

# ── Rate limiting (§10) ──────────────────────────────────────────────────────
# The general API limiter pairs a generous 15-min steady-state allowance with a
# short burst window that trips a rapid page-reload flood the steady state can't
# notice. Both feed the same escalation ladder (20s → 1m → 3m → 10m) and decay
# after ~15 min of good behavior. Defaults are sized so multi-tab TanStack
# refetch bursts never trip; only raise the limit if legitimate use is blocked.
RATE_LIMIT_BURST_WINDOW_SEC=10
RATE_LIMIT_BURST_LIMIT=60

# ── Observability: Prometheus + Grafana (§13.5 V5-P2 arc (a), §16 2026-07-17) ─
# Self-provisioned monitoring inside the deploy stack — no external account, no
# manual dashboard import. Prometheus scrapes the API metrics listener over the
# internal docker network; Grafana auto-wires the datasource + starter dashboard
# on first boot. See docs/ops.md "Observability" for how to reach it.
#
# EXPOSURE GUARANTEE: these surfaces bind to BT_OBS_BIND_HOST ONLY and are never
# routed through the public web/nginx front proxy. Keep the default 127.0.0.1 to
# reach Grafana over an SSH tunnel; set a LAN IP (e.g. 192.168.1.10) to reach it
# from other machines on your LAN. NEVER set it to 0.0.0.0 on a public host.
BT_OBS_BIND_HOST=127.0.0.1
# Host ports (bound to BT_OBS_BIND_HOST above). Grafana is the dashboard UI.
BT_GRAFANA_PORT=3001
BT_PROMETHEUS_PORT=9090
# Grafana local-admin bootstrap — CHANGE THIS before first boot. Sign-up is
# disabled; the localhost/LAN + auth-gated-subdomain paths use this login.
BT_GRAFANA_ADMIN_USER=admin
BT_GRAFANA_ADMIN_PASSWORD=CHANGE_ME_BEFORE_FIRST_BOOT

# ── External access to Grafana (owner directive 2026-07-19) ──────────────────
# By default the dashboards stay localhost/LAN-only (the bind above). To reach
# Grafana from OUTSIDE the LAN — only ever through an AUTHENTICATED path, never
# a raw-public endpoint — pick ONE path below. Prometheus is NEVER exposed
# either way. See docs/monitoring.md for the full walkthrough.
#
# HARD RULE: nothing is exposed while BT_GRAFANA_ADMIN_PASSWORD is unset or left
# at the placeholder above — the app refuses external exposure rather than
# shipping admin/admin to the internet. The runtime kill-switch on the admin
# Diagnostics page can also cut external reach with no redeploy.
BT_OBS_EXTERNAL_ACCESS=false
#
# PRIMARY — proxy through the admin app (inherits admin auth). Grafana stays on
# the localhost/LAN bind; the admin API proxies to it behind the admin login, so
# the only public door is the already-auth-gated admin dashboard. Set:
#   BT_OBS_EXTERNAL_ACCESS=true
#   BT_GRAFANA_SERVE_FROM_SUB_PATH=true
#   BT_GRAFANA_ROOT_URL=https://api.<your-domain>/api/v1/admin/monitoring/grafana/
#   BT_GRAFANA_ANON_ENABLED=true   # the proxy IS the auth; anon Viewer avoids a 2nd login
BT_GRAFANA_SERVE_FROM_SUB_PATH=false
BT_GRAFANA_ROOT_URL=http://localhost:3000/
BT_GRAFANA_ANON_ENABLED=false
BT_GRAFANA_ALLOW_EMBEDDING=true
#
# ALTERNATIVE — auth-gated subdomain (Grafana keeps its own login + HTTPS at the
# edge). Point the edge reverse proxy at Grafana and advertise the public URL so
# the admin Diagnostics panel embeds it:
#   BT_OBS_EXTERNAL_ACCESS=true
#   BT_GRAFANA_PUBLIC_URL=https://grafana.<your-domain>
BT_GRAFANA_PUBLIC_URL=
#
# Where the api reaches the stack internally (probe + proxy upstream). Defaults
# match the compose service names; only change these if you renamed them.
BT_GRAFANA_INTERNAL_URL=http://grafana:3000
BT_PROMETHEUS_INTERNAL_URL=http://prometheus:9090
# API metrics listener. In compose the api container binds 0.0.0.0 internally so
# Prometheus can scrape api:9464 — the port is not published, so it is never
# public. Set BT_METRICS_ENABLED=false to bind no metrics port at all.
BT_METRICS_ENABLED=true
BT_METRICS_PORT=9464

# ── First admin (seed on first boot only) ────────────────────────────────────
# Run once after migrations: docker compose run --rm api node dist/scripts/seed.js
# If the admin already exists the seed script is a no-op (safe to re-run).
ADMIN_EMAIL=admin@example.at
ADMIN_PASSWORD=CHANGE_ME_IMMEDIATELY_AFTER_FIRST_LOGIN

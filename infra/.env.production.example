# Copy to infra/.env and fill in all required values before running compose.
# See PROJECTPLAN.md §11 for the full configuration reference.

# ── Database ────────────────────────────────────────────────────────────────
# Credentials used by both the db service and the api service.
# DATABASE_URL must use the compose service hostname "db", not localhost.
POSTGRES_USER=bt
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=bettertrack
DATABASE_URL=postgres://bt:CHANGE_ME_STRONG_PASSWORD@db:5432/bettertrack

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── API ──────────────────────────────────────────────────────────────────────
# SESSION_SECRET: 64 random bytes (hex). Generate with:
#   openssl rand -hex 64
# Comma-separate multiple secrets for zero-downtime rotation (first signs new cookies).
SESSION_SECRET=CHANGE_ME_64_RANDOM_HEX_BYTES

# ── Deployment topology (§4.6, §10, §11) ─────────────────────────────────────
# One scheme drives the api/web/admin origins; CORS allowlist + cookie Secure/
# SameSite are DERIVED from it (never hand-maintained). Pick ONE mode.
#
# Mode A — subdomains (default). Front this proxy with TLS (Caddy/Traefik/
# Cloudflare) and point five DNS records at it (see README "Production deploy").
# Origins become:
#   product → https://track.example.at            (apex — the static landing page)
#   web     → https://web.track.example.at
#   admin   → https://admin.track.example.at
#   api     → https://api.track.example.at
#   mobile  → https://mobile.track.example.at     (static placeholder)
BT_MODE=subdomains
BT_DOMAIN=track.example.at
# Front-proxy TLS. Leave blank for the per-mode default (subdomains → https).
BT_TLS=
# Subdomain labels (change to taste; the same web image serves web + admin). The
# product landing has NO label — it lives at the BT_DOMAIN apex; mobile. is the
# static placeholder subdomain.
BT_SUB_API=api
BT_SUB_WEB=web
BT_SUB_ADMIN=admin
BT_SUB_MOBILE=mobile
# Host port the proxy listens on (subdomains mode). Terminate TLS in front of it.
# The one proxy port fronts all five origins.
BT_HTTP_PORT=80
#
# Mode B — ports. One host, each service on its own port. To use it, set:
#   BT_MODE=ports
#   BT_DOMAIN=track.example.at   (or a bare IP)
#   BT_TLS=false                 (or true if you terminate TLS in front)
# and the ports below. Origins become http(s)://{BT_DOMAIN}:{port}. PRODUCT and
# MOBILE front the static landing pages, proxied to the internal landing container.
BT_PORT_API=3000
BT_PORT_WEB=8080
BT_PORT_ADMIN=8081
BT_PORT_PRODUCT=8082
BT_PORT_MOBILE=8083
#
# Explicit origin overrides — win over derivation (split hosting / legacy).
# APP_ORIGIN is a legacy alias for BT_WEB_ORIGIN. The static product/mobile pages
# take no credentials, so they never enter the CORS allowlist regardless.
BT_API_ORIGIN=
BT_WEB_ORIGIN=
BT_ADMIN_ORIGIN=
BT_PRODUCT_ORIGIN=
BT_MOBILE_ORIGIN=

# ── SMTP (optional) ──────────────────────────────────────────────────────────
# Leave empty to keep the email channel disabled; the app still runs fully.
# Both SMTP_HOST and SMTP_FROM must be set to enable email delivery.
#
# Gmail preset (recommended): create an App Password (Google Account → Security →
# 2-Step Verification → App passwords) and use it as SMTP_PASS.
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-16-char-app-password
#   SMTP_FROM=BetterTrack <you@gmail.com>
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Push channels (optional, #368) ───────────────────────────────────────────
# Phone push (FCM HTTP v1): absolute in-container path to the Firebase
# service-account JSON, mounted read-only via a compose override — the key is a
# SERVER SECRET and never belongs in a repo or image. Unset (or file missing)
# ⇒ the channel is cleanly disabled with one boot warn; nothing crashes.
BT_FCM_SERVICE_ACCOUNT_FILE=
# Browser push (web-push/VAPID): generate a pair with `npx web-push
# generate-vapid-keys`. Both keys set ⇒ the "Browser push" column appears in
# notification settings. Subject defaults to mailto:admin@$BT_DOMAIN.
BT_VAPID_PUBLIC_KEY=
BT_VAPID_PRIVATE_KEY=
BT_VAPID_SUBJECT=

# ── Backups (§10) ────────────────────────────────────────────────────────────
# infra/backup/backup.sh runs inside the `db` container (host cron triggers it
# nightly) and writes a gzip'd pg_dump into the `pgbackups` volume, pruning
# anything older than BACKUP_RETENTION_DAYS. See README.md "Backups & restore"
# for the cron line and the restore procedure.
BACKUP_RETENTION_DAYS=14

# ── Rate limiting (§10) ──────────────────────────────────────────────────────
# The general API limiter pairs a generous 15-min steady-state allowance with a
# short burst window that trips a rapid page-reload flood the steady state can't
# notice. Both feed the same escalation ladder (20s → 1m → 3m → 10m) and decay
# after ~15 min of good behavior. Defaults are sized so multi-tab TanStack
# refetch bursts never trip; only raise the limit if legitimate use is blocked.
RATE_LIMIT_BURST_WINDOW_SEC=10
RATE_LIMIT_BURST_LIMIT=60

# ── First admin (seed on first boot only) ────────────────────────────────────
# Run once after migrations: docker compose run --rm api node dist/scripts/seed.js
# If the admin already exists the seed script is a no-op (safe to re-run).
ADMIN_EMAIL=admin@example.at
ADMIN_PASSWORD=CHANGE_ME_IMMEDIATELY_AFTER_FIRST_LOGIN

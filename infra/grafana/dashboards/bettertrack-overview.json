    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Market cache hit rate (hits ÷ all lookups) over the last 5 minutes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 35 },
      "id": 7,
      "options": {
        "colorMode": "value",

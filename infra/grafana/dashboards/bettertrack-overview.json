        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (provider, outcome) (rate(bettertrack_provider_calls_total[5m]))",
          "legendFormat": "{{provider}} · {{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Provider calls",

        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(bettertrack_market_cache_events_total{result=\"hit\"}[5m])) / clamp_min(sum(rate(bettertrack_market_cache_events_total[5m])), 1)",
          "refId": "A"
        }
      ],
      "title": "Cache hit rate",
      "type": "stat"
    },
    {

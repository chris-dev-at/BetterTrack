# BetterTrack Build Factory Environment
# Copy to factory/.env and fill the secret values locally. Never commit factory/.env.

# GitHub repo to automate
REPO=chris-dev-at/BetterTrack

# Fine-grained GitHub PAT for this repo only.
# Required permissions: Contents RW, Issues RW, Pull requests RW, Actions R.
GH_TOKEN=replace_me

# Claude Code subscription token from: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=replace_me

# Optional Discord/ntfy/etc webhook for merge/failure/limit notifications.
FACTORY_WEBHOOK_URL=

# Planner/factory controls
MIN_BACKLOG=3
PLANNER_BATCH=5
MAX_FIX_ROUNDS=2
LIMIT_SLEEP=1800
STUCK_LIMIT=5
AFTER_V1=propose
ONE_SHOT=0
